{
  "name": "platformax-v2",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:v2": "eslint client/src/app-v2 client/src/features-v2 server/domains-v2 --max-warnings=0 --no-error-on-unmatched-pattern",
    "test": "vitest run",
    "rules:check": "node scripts/rules-check.mjs",
    "arch:check:v2": "node scripts/arch-check-v2.mjs",
    "guards:diff": "node scripts/check-diff-safety.mjs",
    "guards:commit": "node scripts/no-commit-if-dirty-gates.mjs",
    "guards:bundle": "node scripts/validate-bundle.mjs --smoke",
    "guards:secrets": "node scripts/check-secret-scan.mjs",
    "guards:boundaries": "node scripts/audit-domain-boundaries.mjs",
    "guards:complexity": "node scripts/check-file-complexity.mjs",
    "guards:migrations": "node scripts/check-supabase-migrations-safety.mjs",
    "guards:scripts": "node scripts/check-script-safety.mjs",
    "guards:domains": "node scripts/check-domain-registry.mjs && node scripts/check-domain-scaffold.mjs && node scripts/check-feature-registry.mjs",
    "guards:review": "node scripts/check-review-reports-index.mjs && node scripts/check-pre-commit-decision.mjs && node scripts/check-self-audit-evidence.mjs",
    "guards:self-audit": "node scripts/check-self-audit-evidence.mjs",
    "guards:bramka": "node scripts/check-bramka-acceptance.mjs",
    "guards:all-local": "node scripts/rules-check.mjs && node scripts/check-secret-scan.mjs && node scripts/check-local-secret-scan.mjs && node scripts/check-script-safety.mjs && node scripts/check-review-reports-index.mjs && node scripts/check-pre-commit-decision.mjs && node scripts/check-self-audit-evidence.mjs && node scripts/check-bramka-acceptance.mjs",
    "scaffold:domain": "node scripts/scaffold-domain.mjs",
    "scaffold:ui-shell": "node scripts/scaffold-ui-shell.mjs",
    "scaffold:route": "node scripts/scaffold-route.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored"
    ],
    "*.{js,mjs}": [
      "eslint --max-warnings=0 --no-warn-ignored"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.27.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "adm-zip": "^0.5.17",
    "eslint": "^9.27.0",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.5",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.32.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  }
}
