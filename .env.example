# PlatformaX V2 - Environment Variables
# Copy this file to .env and fill in the values

# App
VITE_APP_NAME=PlatformaX
VITE_APP_VERSION=0.0.1

# API (placeholder - no real secrets)
VITE_API_URL=http://localhost:3000

# Supabase Auth (frontend) - public values only, no secrets
# Only the anon/public key belongs in the frontend.
# NEVER put the service role key or a database connection string here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server
PORT=3000
NODE_ENV=development
